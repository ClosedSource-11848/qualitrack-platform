@startuml laboratory-backend-diagram

title QualiTrack - Laboratory Backend Class Diagram

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

package "shared" <<External>> {
  abstract class AbstractDomainAggregateRoot
  abstract class AuditableAbstractPersistenceEntity
  class ApplicationError
  class Result
}

package "ca.interfaces.acl" <<External>> {
  interface ComplianceContextFacade
}

package "laboratory.domain.model.valueobjects" {
  class LaboratoryName <<value object>>
  class Regulation <<value object>>
  class StockQuantity <<value object>>

  enum LaboratoryStatus {
    ACTIVE
    INACTIVE
  }
}

package "laboratory.domain.model.entities" {
  class LaboratoryAddress {
    - street: String
    - city: String
    - country: String
  }
}

package "laboratory.domain.model.aggregates" {
  class Laboratory {
    - id: Long
    - name: LaboratoryName
    - ruc: String
    - address: LaboratoryAddress
    - phone: String
    - regulations: List<Regulation>
    - status: LaboratoryStatus
    + updateProfile(command: UpdateLaboratoryCommand): void
  }

  class PharmaceuticalProduct {
    - id: Long
    - laboratoryId: Long
    - code: String
    - name: String
    - description: String
    - unit: String
  }

  class RawMaterial {
    - id: Long
    - laboratoryId: Long
    - code: String
    - name: String
    - unit: String
    - currentStock: Integer
    - minimumThreshold: Integer
  }

  class StaffMember {
    - id: Long
    - laboratoryId: Long
    - fullName: String
    - role: String
    - email: String
    - active: Boolean
    + deactivate(): void
  }
}

Laboratory --|> AbstractDomainAggregateRoot
PharmaceuticalProduct --|> AbstractDomainAggregateRoot
RawMaterial --|> AbstractDomainAggregateRoot
StaffMember --|> AbstractDomainAggregateRoot

Laboratory *-- LaboratoryName
Laboratory *-- LaboratoryAddress
Laboratory *-- Regulation
Laboratory *-- LaboratoryStatus
RawMaterial *-- StockQuantity

package "laboratory.domain.model.commands" {
  record CreateLaboratoryCommand
  record UpdateLaboratoryCommand
  record CreateProductCommand
  record CreateRawMaterialCommand
  record RegisterStaffCommand
  record DeactivateStaffCommand
}

package "laboratory.domain.model.queries" {
  record GetLaboratoryByIdQuery
  record GetProductsByLabIdQuery
  record GetRawMaterialsByLabIdQuery
  record GetLowStockMaterialsByLabIdQuery
  record GetStaffByLabIdQuery
}

package "laboratory.domain.model.events" {
  record LaboratoryRegisteredEvent
  record ProductCreatedEvent
  record RawMaterialCreatedEvent
  record RawMaterialLowStockEvent
  record StaffRegisteredEvent
  record StaffDeactivatedEvent
}

package "laboratory.domain.repositories" {
  interface LaboratoryRepository
  interface ProductRepository
  interface RawMaterialRepository
  interface StaffRepository
}

package "laboratory.domain.exceptions" {
  class LaboratoryNotFoundException
  class ProductNotFoundException
  class RawMaterialNotFoundException
  class StaffMemberNotFoundException
}

package "laboratory.application.commandservices" {
  interface LaboratoryCommandService
  interface ProductCommandService
  interface RawMaterialCommandService
  interface StaffCommandService
}

package "laboratory.application.queryservices" {
  interface LaboratoryQueryService
  interface ProductQueryService
  interface RawMaterialQueryService
  interface StaffQueryService
}

package "laboratory.application.internal.commandservices" {
  class LaboratoryCommandServiceImpl
  class ProductCommandServiceImpl
  class RawMaterialCommandServiceImpl
  class StaffCommandServiceImpl
}

LaboratoryCommandServiceImpl ..|> LaboratoryCommandService
ProductCommandServiceImpl ..|> ProductCommandService
RawMaterialCommandServiceImpl ..|> RawMaterialCommandService
StaffCommandServiceImpl ..|> StaffCommandService

LaboratoryCommandServiceImpl --> LaboratoryRepository
ProductCommandServiceImpl --> ProductRepository
ProductCommandServiceImpl --> LaboratoryRepository
RawMaterialCommandServiceImpl --> RawMaterialRepository
RawMaterialCommandServiceImpl --> LaboratoryRepository
StaffCommandServiceImpl --> StaffRepository
StaffCommandServiceImpl --> LaboratoryRepository

package "laboratory.application.internal.queryservices" {
  class LaboratoryQueryServiceImpl
  class ProductQueryServiceImpl
  class RawMaterialQueryServiceImpl
  class StaffQueryServiceImpl
}

LaboratoryQueryServiceImpl ..|> LaboratoryQueryService
ProductQueryServiceImpl ..|> ProductQueryService
RawMaterialQueryServiceImpl ..|> RawMaterialQueryService
StaffQueryServiceImpl ..|> StaffQueryService

LaboratoryQueryServiceImpl --> LaboratoryRepository
ProductQueryServiceImpl --> ProductRepository
RawMaterialQueryServiceImpl --> RawMaterialRepository
StaffQueryServiceImpl --> StaffRepository

package "laboratory.application.internal.eventhandlers" {
  class LaboratoryRegisteredEventHandler
  class ProductCreatedEventHandler
  class RawMaterialCreatedEventHandler
  class RawMaterialLowStockEventHandler
  class StaffRegisteredEventHandler
  class StaffDeactivatedEventHandler
}

LaboratoryRegisteredEventHandler ..> LaboratoryRegisteredEvent
ProductCreatedEventHandler ..> ProductCreatedEvent
RawMaterialCreatedEventHandler ..> RawMaterialCreatedEvent
RawMaterialLowStockEventHandler ..> RawMaterialLowStockEvent
StaffRegisteredEventHandler ..> StaffRegisteredEvent
StaffDeactivatedEventHandler ..> StaffDeactivatedEvent

package "laboratory.application.internal.outboundservices.acl" {
  class LaboratoryExternalComplianceService
}

LaboratoryExternalComplianceService --> ComplianceContextFacade
RawMaterialLowStockEventHandler --> LaboratoryExternalComplianceService

package "laboratory.application.acl" {
  class LaboratoryContextFacadeImpl
}

package "laboratory.interfaces.acl" {
  interface LaboratoryContextFacade
}

LaboratoryContextFacadeImpl ..|> LaboratoryContextFacade
LaboratoryContextFacadeImpl --> LaboratoryRepository
LaboratoryContextFacadeImpl --> ProductRepository
LaboratoryContextFacadeImpl --> RawMaterialRepository
LaboratoryContextFacadeImpl --> StaffRepository

package "laboratory.interfaces.events" {
  record LaboratoryRegisteredIntegrationEvent
  record ProductCreatedIntegrationEvent
  record RawMaterialCreatedIntegrationEvent
  record RawMaterialLowStockIntegrationEvent
  record StaffRegisteredIntegrationEvent
  record StaffDeactivatedIntegrationEvent
}

LaboratoryRegisteredEventHandler ..> LaboratoryRegisteredIntegrationEvent
ProductCreatedEventHandler ..> ProductCreatedIntegrationEvent
RawMaterialCreatedEventHandler ..> RawMaterialCreatedIntegrationEvent
RawMaterialLowStockEventHandler ..> RawMaterialLowStockIntegrationEvent
StaffRegisteredEventHandler ..> StaffRegisteredIntegrationEvent
StaffDeactivatedEventHandler ..> StaffDeactivatedIntegrationEvent

package "laboratory.infrastructure.persistence.jpa.entities" {
  class LaboratoryPersistenceEntity
  class ProductPersistenceEntity
  class RawMaterialPersistenceEntity
  class StaffPersistenceEntity
}

LaboratoryPersistenceEntity --|> AuditableAbstractPersistenceEntity
ProductPersistenceEntity --|> AuditableAbstractPersistenceEntity
RawMaterialPersistenceEntity --|> AuditableAbstractPersistenceEntity
StaffPersistenceEntity --|> AuditableAbstractPersistenceEntity

package "laboratory.infrastructure.persistence.jpa.repositories" {
  interface LaboratoryPersistenceRepository <<JpaRepository>>
  interface ProductPersistenceRepository <<JpaRepository>>
  interface RawMaterialPersistenceRepository <<JpaRepository>>
  interface StaffPersistenceRepository <<JpaRepository>>
}

LaboratoryPersistenceRepository --> LaboratoryPersistenceEntity
ProductPersistenceRepository --> ProductPersistenceEntity
RawMaterialPersistenceRepository --> RawMaterialPersistenceEntity
StaffPersistenceRepository --> StaffPersistenceEntity

package "laboratory.infrastructure.persistence.jpa.assemblers" {
  class LaboratoryPersistenceAssembler
  class ProductPersistenceAssembler
  class RawMaterialPersistenceAssembler
  class StaffPersistenceAssembler
}

LaboratoryPersistenceAssembler ..> Laboratory
LaboratoryPersistenceAssembler ..> LaboratoryPersistenceEntity
ProductPersistenceAssembler ..> PharmaceuticalProduct
ProductPersistenceAssembler ..> ProductPersistenceEntity
RawMaterialPersistenceAssembler ..> RawMaterial
RawMaterialPersistenceAssembler ..> RawMaterialPersistenceEntity
StaffPersistenceAssembler ..> StaffMember
StaffPersistenceAssembler ..> StaffPersistenceEntity

package "laboratory.infrastructure.persistence.jpa.adapters" {
  class LaboratoryRepositoryImpl
  class ProductRepositoryImpl
  class RawMaterialRepositoryImpl
  class StaffRepositoryImpl
}

LaboratoryRepositoryImpl ..|> LaboratoryRepository
ProductRepositoryImpl ..|> ProductRepository
RawMaterialRepositoryImpl ..|> RawMaterialRepository
StaffRepositoryImpl ..|> StaffRepository

LaboratoryRepositoryImpl --> LaboratoryPersistenceRepository
ProductRepositoryImpl --> ProductPersistenceRepository
RawMaterialRepositoryImpl --> RawMaterialPersistenceRepository
StaffRepositoryImpl --> StaffPersistenceRepository

LaboratoryRepositoryImpl --> LaboratoryPersistenceAssembler
ProductRepositoryImpl --> ProductPersistenceAssembler
RawMaterialRepositoryImpl --> RawMaterialPersistenceAssembler
StaffRepositoryImpl --> StaffPersistenceAssembler

package "laboratory.infrastructure.persistence.jpa.converters" {
  class LaboratoryAddressPersistenceConverter
  class LaboratoryStatusPersistenceConverter
  class RegulationPersistenceConverter
}

LaboratoryAddressPersistenceConverter ..> LaboratoryAddress
LaboratoryStatusPersistenceConverter ..> LaboratoryStatus
RegulationPersistenceConverter ..> Regulation

package "laboratory.interfaces.rest.resources" {
  record CreateLaboratoryResource
  record UpdateLaboratoryResource
  record LaboratoryResource
  record CreateProductResource
  record PharmaceuticalProductResource
  record CreateRawMaterialResource
  record RawMaterialResource
  record RegisterStaffResource
  record StaffMemberResource
}

package "laboratory.interfaces.rest.transform" {
  class CreateLaboratoryCommandFromResourceAssembler
  class UpdateLaboratoryCommandFromResourceAssembler
  class LaboratoryResourceFromEntityAssembler
  class CreateProductCommandFromResourceAssembler
  class ProductResourceFromEntityAssembler
  class CreateRawMaterialCommandFromResourceAssembler
  class RawMaterialResourceFromEntityAssembler
  class RegisterStaffCommandFromResourceAssembler
  class StaffResourceFromEntityAssembler
}

CreateLaboratoryCommandFromResourceAssembler ..> CreateLaboratoryResource
CreateLaboratoryCommandFromResourceAssembler ..> CreateLaboratoryCommand
UpdateLaboratoryCommandFromResourceAssembler ..> UpdateLaboratoryResource
UpdateLaboratoryCommandFromResourceAssembler ..> UpdateLaboratoryCommand
LaboratoryResourceFromEntityAssembler ..> Laboratory
LaboratoryResourceFromEntityAssembler ..> LaboratoryResource

CreateProductCommandFromResourceAssembler ..> CreateProductResource
CreateProductCommandFromResourceAssembler ..> CreateProductCommand
ProductResourceFromEntityAssembler ..> PharmaceuticalProduct
ProductResourceFromEntityAssembler ..> PharmaceuticalProductResource

CreateRawMaterialCommandFromResourceAssembler ..> CreateRawMaterialResource
CreateRawMaterialCommandFromResourceAssembler ..> CreateRawMaterialCommand
RawMaterialResourceFromEntityAssembler ..> RawMaterial
RawMaterialResourceFromEntityAssembler ..> RawMaterialResource

RegisterStaffCommandFromResourceAssembler ..> RegisterStaffResource
RegisterStaffCommandFromResourceAssembler ..> RegisterStaffCommand
StaffResourceFromEntityAssembler ..> StaffMember
StaffResourceFromEntityAssembler ..> StaffMemberResource

package "laboratory.interfaces.rest" {
  class LaboratoryController
  class LaboratoryProductsController
  class LaboratoryRawMaterialsController
  class LaboratoryStaffController
  class StaffController
}

LaboratoryController --> LaboratoryCommandService
LaboratoryController --> LaboratoryQueryService

LaboratoryProductsController --> ProductCommandService
LaboratoryProductsController --> ProductQueryService

LaboratoryRawMaterialsController --> RawMaterialCommandService
LaboratoryRawMaterialsController --> RawMaterialQueryService

LaboratoryStaffController --> StaffCommandService
LaboratoryStaffController --> StaffQueryService

StaffController --> StaffCommandService
StaffController --> StaffQueryService

LaboratoryController ..> LaboratoryResourceFromEntityAssembler
LaboratoryController ..> CreateLaboratoryCommandFromResourceAssembler
LaboratoryController ..> UpdateLaboratoryCommandFromResourceAssembler

LaboratoryProductsController ..> ProductResourceFromEntityAssembler
LaboratoryProductsController ..> CreateProductCommandFromResourceAssembler

LaboratoryRawMaterialsController ..> RawMaterialResourceFromEntityAssembler
LaboratoryRawMaterialsController ..> CreateRawMaterialCommandFromResourceAssembler

LaboratoryStaffController ..> StaffResourceFromEntityAssembler
LaboratoryStaffController ..> RegisterStaffCommandFromResourceAssembler
StaffController ..> StaffResourceFromEntityAssembler

@enduml