@startuml qualitrack-database-diagram
title QualiTrack - Complete Database Diagram by Bounded Contexts

skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
hide circle
hide methods
hide stereotypes

package "IAM Context" {
  entity "iam_users" as iam_users {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * username : VARCHAR(80) <<UK>>
    * password : VARCHAR(255)
    laboratory_id : BIGINT
    * status : VARCHAR(50)
  }

  entity "iam_roles" as iam_roles {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * name : VARCHAR(80) <<UK>>
  }

  entity "iam_user_roles" as iam_user_roles {
    * user_id : BIGINT <<FK>>
    * role_id : BIGINT <<FK>>
  }

  iam_users ||--o{ iam_user_roles : "user_id"
  iam_roles ||--o{ iam_user_roles : "role_id"
}

package "Laboratory Context" {
  entity "laboratories" as laboratories {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * name : VARCHAR(100)
    * ruc : VARCHAR(20) <<UK>>
    * address : VARCHAR(255)
    * phone : VARCHAR(50)
    * status : VARCHAR(255)
  }

  entity "laboratory_regulations" as laboratory_regulations {
    * laboratory_id : BIGINT <<FK>>
    * regulation : VARCHAR(255)
  }

  entity "staff_members" as staff_members {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT <<FK>>
    * full_name : VARCHAR(150)
    * role : VARCHAR(100)
    * email : VARCHAR(150) <<UK>>
    * active : BOOLEAN
  }

  entity "pharmaceutical_products" as pharmaceutical_products {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT <<FK>>
    * code : VARCHAR(50) <<UK>>
    * name : VARCHAR(150)
    description : VARCHAR(500)
    * specifications : VARCHAR(1000)
    * active : BOOLEAN
  }

  entity "raw_materials" as raw_materials {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT <<FK>>
    * name : VARCHAR(150)
    * code : VARCHAR(50) <<UK>>
    * supplier : VARCHAR(150)
    * batch_number : VARCHAR(50)
    * expiration_date : VARCHAR(20)
    * quantity_in_stock : INT
    * unit : VARCHAR(20)
    * minimum_stock : INT
  }

  laboratories ||--o{ laboratory_regulations : "laboratory_id"
  laboratories ||--o{ staff_members : "laboratory_id"
  laboratories ||--o{ pharmaceutical_products : "laboratory_id"
  laboratories ||--o{ raw_materials : "laboratory_id"
}

package "Equipment Context" {
  entity "equipment" as equipment {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT
    * name : VARCHAR(150)
    * type : VARCHAR(100)
    * model : VARCHAR(100)
    * serial_number : VARCHAR(50) <<UK>>
    * status : VARCHAR(50)
    sensor_external_id : VARCHAR(50)
  }

  entity "bpm_parameter_configs" as bpm_parameter_configs {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT <<FK>>
    * parameter_name : VARCHAR(100)
    * min_value : DOUBLE
    * max_value : DOUBLE
    * unit : VARCHAR(20)
  }

  entity "maintenance_records" as maintenance_records {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT <<FK>>
    * maintenance_date : DATE
    * technician_name : VARCHAR(150)
    * description : VARCHAR(1000)
    * type : VARCHAR(50)
  }

  equipment ||--o{ bpm_parameter_configs : "equipment_id"
  equipment ||--o{ maintenance_records : "equipment_id"
}

package "Batch Context" {
  entity "batches" as batches {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT
    * product_id : BIGINT
    * product_name : VARCHAR(150)
    * batch_number : VARCHAR(50) <<UK>>
    * quantity : DOUBLE
    * unit : VARCHAR(20)
    * status : VARCHAR(50)
    * start_date : VARCHAR(30)
    end_date : VARCHAR(30)
    notes : VARCHAR(500)
  }

  entity "raw_material_usages" as raw_material_usages {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * batch_id : BIGINT <<FK>>
    * raw_material_id : BIGINT
    * raw_material_name : VARCHAR(150)
    * quantity_used : DOUBLE
    * unit : VARCHAR(20)
    * usage_date : VARCHAR(30)
  }

  entity "digital_signatures" as digital_signatures {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * batch_id : BIGINT <<FK>>
    * signed_by_user_id : BIGINT
    * signature_hash : VARCHAR(255)
    * signed_at : VARCHAR(30)
  }

  entity "rejection_records" as rejection_records {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * batch_id : BIGINT <<FK>>
    * rejection_date : VARCHAR(30)
    * reason : VARCHAR(500)
  }

  batches ||--o{ raw_material_usages : "batch_id"
  batches ||--o{ digital_signatures : "batch_id"
  batches ||--o{ rejection_records : "batch_id"
}

package "Tracking Context" {
  entity "equipment_telemetry" as equipment_telemetry {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT <<UK>>
  }

  entity "equipment_telemetry_statuses" as equipment_telemetry_statuses {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT
    * is_online : BOOLEAN
    * current_status : VARCHAR(40)
    * last_heartbeat : VARCHAR(50)
  }

  entity "telemetry_measurements" as telemetry_measurements {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT
    * parameter_name : VARCHAR(120)
    * value : DOUBLE
    * unit : VARCHAR(40)
    * timestamp : VARCHAR(50)
  }

  entity "telemetry_history_points" as telemetry_history_points {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT
    * parameter_name : VARCHAR(120)
    * recorded_value : DOUBLE
    * timestamp : VARCHAR(50)
    * is_anomaly : BOOLEAN
  }

  equipment_telemetry ||--o{ equipment_telemetry_statuses : "equipment_id"
  equipment_telemetry ||--o{ telemetry_measurements : "equipment_id"
  equipment_telemetry ||--o{ telemetry_history_points : "equipment_id"
}

package "Compliance and Alerts Context" {
  entity "deviation_alerts" as deviation_alerts {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * equipment_id : BIGINT
    batch_id : BIGINT
    * parameter_name : VARCHAR(100)
    * recorded_value : DOUBLE
    * threshold_value : DOUBLE
    * unit : VARCHAR(20)
    * timestamp : VARCHAR(30)
    * severity : VARCHAR(50)
    * status : VARCHAR(50)
    acknowledged_by : BIGINT
    resolved_by : BIGINT
    resolution_notes : VARCHAR(500)
  }

  entity "compliance_events" as compliance_events {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * related_entity_id : BIGINT
    * event_type : VARCHAR(100)
    * description : VARCHAR(1000)
    * timestamp : VARCHAR(30)
    resolved_by : BIGINT
  }

  entity "notification_preferences" as notification_preferences {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * user_id : BIGINT <<UK>>
    * email_enabled : BOOLEAN
    * sms_enabled : BOOLEAN
    * in_app_enabled : BOOLEAN
    * minimum_severity : VARCHAR(50)
  }
}

package "Reporting and Analysis Context" {
  entity "audit_reports" as audit_reports {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT
    batch_id : BIGINT
    equipment_id : BIGINT
    * generated_by : BIGINT
    * generated_by_name : VARCHAR(150)
    * report_type : VARCHAR(50)
    date_range_from : VARCHAR(30)
    date_range_to : VARCHAR(30)
    * file_path : VARCHAR(500)
    * checksum : VARCHAR(255)
    * generated_at : VARCHAR(30)
  }

  entity "audit_log_entries" as audit_log_entries {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * action : VARCHAR(50)
    * entity_type : VARCHAR(100)
    entity_id : BIGINT
    * performed_by : BIGINT
    * timestamp : VARCHAR(30)
    details : VARCHAR(1000)
  }

  entity "kpi_dashboards" as kpi_dashboards {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * laboratory_id : BIGINT
    * timestamp : VARCHAR(30)
    * overall_health_score : DOUBLE
  }

  entity "kpi_metrics" as kpi_metrics {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * dashboard_id : BIGINT <<FK>>
    * name : VARCHAR(100)
    * value : DOUBLE
    * unit : VARCHAR(20)
    * target_value : DOUBLE
    * status : VARCHAR(50)
    * recorded_at : VARCHAR(30)
  }

  entity "deviation_trends" as deviation_trends {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * parameter_name : VARCHAR(100)
    * equipment_id : BIGINT
    * trend_direction : VARCHAR(50)
  }

  entity "trend_data_points" as trend_data_points {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * trend_id : BIGINT <<FK>>
    * timestamp : VARCHAR(30)
    * recorded_value : DOUBLE
    * upper_threshold : DOUBLE
    * lower_threshold : DOUBLE
  }

  kpi_dashboards ||--o{ kpi_metrics : "dashboard_id"
  deviation_trends ||--o{ trend_data_points : "trend_id"
}

package "Subscription Context" {
  entity "subscription_plans" as subscription_plans {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * code : VARCHAR(50)
    * name : VARCHAR(100)
    description : VARCHAR(500)
    * amount : DECIMAL(10,2)
    * currency : VARCHAR(3)
    * billing_cycle : VARCHAR(50)
    stripe_price_id : VARCHAR(150)
    * max_users : INT
    * max_equipment : INT
    * active : BOOLEAN
    --
    <<UK>> code, billing_cycle
    <<UK>> stripe_price_id
  }

  entity "subscriptions" as subscriptions {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * user_id : BIGINT
    * laboratory_id : BIGINT
    * plan_code : VARCHAR(50)
    * billing_cycle : VARCHAR(50)
    * status : VARCHAR(50)
    stripe_customer_id : VARCHAR(150)
    stripe_subscription_id : VARCHAR(150)
    stripe_checkout_session_id : VARCHAR(150)
    current_period_start : VARCHAR(50)
    current_period_end : VARCHAR(50)
    cancelled_at : VARCHAR(50)
    cancelled_by : BIGINT
    --
    <<UK>> stripe_subscription_id
    <<UK>> stripe_checkout_session_id
  }

  entity "subscription_payments" as subscription_payments {
    * id : BIGINT <<PK>>
    --
    * created_at : DATETIME
    * updated_at : DATETIME
    * subscription_id : BIGINT <<FK>>
    * provider : VARCHAR(50)
    provider_payment_id : VARCHAR(150)
    stripe_checkout_session_id : VARCHAR(150)
    * amount : DECIMAL(10,2)
    * currency : VARCHAR(3)
    * status : VARCHAR(50)
    paid_at : VARCHAR(50)
    --
    <<UK>> provider_payment_id
    <<UK>> stripe_checkout_session_id
  }

  subscription_plans ||..o{ subscriptions : "code + billing_cycle"
  subscriptions ||--o{ subscription_payments : "subscription_id"
}

@enduml